# Life OS environment variables
# Copy this file to .env and fill in the values you need.
# Only DATABASE_URL is required for local development.

# ── Required ─────────────────────────────────────────────────────────────────

# SQLite database file path (relative to project root)
DATABASE_URL="file:./prisma/data.db"

# ── Optional: Notion sync ─────────────────────────────────────────────────────
# One-way mirror of local data to a Notion database for mobile read access.
# Leave blank if you don't use Notion.

NOTION_API_KEY=""
# The ID of the Notion database to sync tasks into
NOTION_TASKS_DATABASE_ID="your-notion-database-id-here"
# How often to sync, in minutes (default: 5)
NOTION_SYNC_INTERVAL_MIN=5

# ── Optional: App behaviour ───────────────────────────────────────────────────

# How often the coaching nudge fires, in minutes (default: 15)
COACHING_TICK_INTERVAL_MIN=15

# ── Optional: Vault / knowledge-base path ────────────────────────────────────
# Absolute path to a local markdown vault used by the prompt-generation feature.
# Leave blank if you don't use this integration.
VAULT_PATH="/absolute/path/to/your/vault"
