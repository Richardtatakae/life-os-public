{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Life OS",
  "version": "0.1.0",
  "identifier": "com.lifeos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public",
    "frontendDist": "../dist-placeholder"
  },
  "app": {
    "windows": [
      {
        "title": "Life OS",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "url": "http://127.0.0.1:3737"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first life management dashboard",
    "longDescription": "Life OS consolidates habit tracking, streak progression, task management, goal progression, daily scheduling, and proactive coaching into one local-first dashboard.",
    "resources": {
      "../.next/standalone": "standalone",
      "../prisma/data.db": "data.db.template"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
